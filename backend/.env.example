# VEGA — Environment Configuration
# Copy to .env and fill in your values

# Application
VEGA_DEBUG=true
VEGA_HOST=0.0.0.0
VEGA_PORT=8000

# Authentication — pre-shared key for ESP32 sensor boxes
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
VEGA_API_KEY=change-me-to-a-secret-value

# Database (SQLite for dev, Postgres for prod)
VEGA_DATABASE_URL=sqlite+aiosqlite:///vega.db

# MQTT / The Things Network
VEGA_MQTT_BROKER=eu1.cloud.thethings.network
VEGA_MQTT_PORT=1883
VEGA_MQTT_USERNAME=your-ttn-application@tenant
VEGA_MQTT_PASSWORD=your-ttn-api-key

# Citizen web app
VEGA_CITIZEN_BASE_URL=http://localhost:8000

# Gamification tuning
VEGA_POINTS_PER_WATERING=10
VEGA_POINTS_PER_PHOTO=5
VEGA_POINTS_PER_REFERRAL=25
VEGA_STREAK_BONUS_MULTIPLIER=1.5
